# ═══════════════════════════════════════════════════════════════════════════════
# RAKT-CONNECT — Environment Configuration Template
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════════════════

# ── API Gateway ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-here
SESSION_SECRET=your-session-secret-here

# ── Hyperledger Fabric ───────────────────────────────────────────────────────
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_ORDERER_ENDPOINT=localhost:7050
FABRIC_CHANNEL_NAME=rakt-channel
FABRIC_CHAINCODE_NAME=compliance-engine
FABRIC_MSP_ID=HospitalMSP

# ── CouchDB ─────────────────────────────────────────────────────────────────
COUCHDB_HOST=localhost
COUCHDB_PORT=5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=adminpw

# ── AI Microservice ──────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_MODEL_PATH=./models

# ── ABDM Integration ────────────────────────────────────────────────────────
ABDM_BASE_URL=https://abdm.gov.in/api/v1
ABDM_CLIENT_ID=your-abdm-client-id
ABDM_CLIENT_SECRET=your-abdm-client-secret
ABDM_CALLBACK_URL=http://localhost:3001/callback/abdm

# ── ABHA Authentication ─────────────────────────────────────────────────────
ABHA_AUTH_URL=https://healthidsbx.abdm.gov.in/api/v1
ABHA_HIP_ID=your-hip-id

# ── Polygon L2 (Donor DID) ──────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-api-key
POLYGON_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
POLYGON_PRIVATE_KEY=your-private-key

# ── NHCX Insurance Gateway ──────────────────────────────────────────────────
NHCX_BASE_URL=https://hcx.swasthalliance.org/api/v1
NHCX_PARTICIPANT_CODE=your-participant-code
NHCX_AUTH_TOKEN=your-auth-token

# ── Tax (80G Compliance) ────────────────────────────────────────────────────
INCOME_TAX_API_URL=https://api.incometax.gov.in/v1
INCOME_TAX_TAN=your-tan-number

# ── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3002
GRAFANA_ADMIN_PASSWORD=raktadmin

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_EMERGENCY_BROADCAST=true
ENABLE_AI_PREDICTIONS=true
ENABLE_POLYGON_DID=false
ENABLE_NHCX_CLAIMS=false
